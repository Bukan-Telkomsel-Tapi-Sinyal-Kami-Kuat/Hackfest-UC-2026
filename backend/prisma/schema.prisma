// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enum untuk Kategorisasi ---

enum DisabilityType {
  AUTISM
  ADHD
  DOWN_SYNDROME
  SENSORY_PROCESSING_DISORDER
  OTHER
}

enum OverloadStatus {
  STABLE
  WARNING
  OVERLOAD
}

enum InstructionType {
  VERBAL
  VISUAL_CARD
  CALMING_MUSIC
  BREAK
}

// 1. TAMBAHKAN ENUM ROLE DI SINI
enum Role {           // <-- TAMBAHKAN INI
  PARENT              // <-- TAMBAHKAN INI
  ADMIN               // <-- TAMBAHKAN INI
}                     // <-- TAMBAHKAN INI

// --- Model Inti ---

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String 
  
  // 2. TAMBAHKAN KOLOM ROLE DI SINI
  role      Role     @default(PARENT) 

  children  Child[]
  createdAt DateTime @default(now())
}

model Child {
  id             String         @id @default(cuid())
  name           String
  birthDate      DateTime
  disabilityType DisabilityType
  parentId       String
  parent         User           @relation(fields: [parentId], references: [id])
  sessions       Session[]
  createdAt      DateTime       @default(now())
}

model Session {
  id             String           @id @default(cuid())
  childId        String
  child          Child            @relation(fields: [childId], references: [id])
  startTime      DateTime         @default(now())
  endTime        DateTime?
  
  // Data agregat untuk ringkasan sesi
  averageEngagement Float?
  
  // Relasi ke data real-time
  behavioralLogs BehavioralLog[]
  prompts        ParentPrompt[]
}

model BehavioralLog {
  id              String         @id @default(cuid())
  sessionId       String
  session         Session        @relation(fields: [sessionId], references: [id])
  timestamp       DateTime       @default(now())
  
  // Data dari MediaPipe / CV
  engagementScore Float
  gazeDirection   String
  microExpression String?
  poseData        Json?          // Koordinat skeletal jika diperlukan
  
  // Deteksi Sensory Overload
  overloadStatus  OverloadStatus @default(STABLE)
}

model ParentPrompt {
  id              String          @id @default(cuid())
  sessionId       String
  session         Session         @relation(fields: [sessionId], references: [id])
  timestamp       DateTime        @default(now())
  
  // Pesan dari AI (Dynamic Prompting)
  aiMessage       String          @db.Text
  instructionType InstructionType
  
  // Feedback Loop: Apakah orang tua mengikuti saran ini?
  parentAcknowledged Boolean     @default(false)
}

model RAGReference {
  id             String         @id @default(cuid())
  disabilityType DisabilityType
  sourceTitle    String
  content        String         @db.Text
  metadata       Json?
  version        String         @default("1.0")
}

model AdminModule {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  category   String
  level      String
  duration   String
  cover      String
  summary    String
  objectives Json
  steps      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}